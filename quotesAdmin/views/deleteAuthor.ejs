<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delete Author</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container">
        <h1>Are you sure you want to delete this author?</h1>

        <form action="/deleteAuthor" method="POST">
            <input type="hidden" name="authorId" value="<%= authorInfo[0].authorId %>">
            <button class="btn btn-danger mt-2">Yes, Delete Author!</button>
        </form>
    </div>

</body>
</html>