<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lab 7: Famous Quotes - Admin Section</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container">
        <h1>Admin Section</h1>

        <form action="/addAuthor" method="GET">
            <button class="btn btn-primary mb-2">Add Authors</button>
        </form>

        <form action="/addQuote">
            <button class="btn btn-primary mb-2">Add Quotes</button>
        </form>

        <form action="/authors" method="GET">
            <button class="btn btn-primary mb-2">All Authors</button>
        </form>

        <form action="/quotes">
            <button class="btn btn-primary mb-2">All Quotes</button>
        </form>
    </div>

</body>
</html>