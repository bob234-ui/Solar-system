<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Quote</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container">
        <h1>Update Quote</h1>

        <form action="/updateQuote" method="POST">
            <input type="hidden" name="quoteId" value="<%= quoteInfo[0].quoteId %>">

            Quote: <textarea name="quote"><%= quoteInfo[0].quote %></textarea><br>

            Category:
            <select name="category">
                <option value="">Select Category</option>
                <% for (let i of categoryList) { %>
                    <option <%=(quoteInfo[0].category == i.category)?"selected":""%> value="<%=i.category%>"><%=i.category%></option>
                <% } %>
            </select><br>

            Author:
            <select name="authorId">
                <option value="">Select Author</option>
                <% for (let i of authorList) { %>
                    <option <%=(quoteInfo[0].authorId == i.authorId)?"selected":""%> value="<%=i.authorId%>"><%=i.firstName%> <%=i.lastName%></option>
                <% } %>
            </select><br>

            <button class="btn btn-primary mt-2">Update Quote!</button>
        </form>
    </div>

</body>
</html>