<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delete Quote</title>
    <!-- <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"> -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <%- include('partials/navbar') %>

        <div class="container">
            <h1>Are you sure you want to delete this quote?</h1>

            <p>
                <%= quoteInfo[0].quote %>
            </p>

            <form action="/deleteQuote" method="POST">
                <input type="hidden" name="quoteId" value="<%= quoteInfo[0].quoteId %>">
                <button class="btn btn-danger mt-2">Yes, Delete Quote!</button>
            </form>
        </div>
</body>

</html>