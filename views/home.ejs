<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head.ejs') %>
</head>
<body>
    <h1 class="bg-info text-white p-3 m-0 page-title">The Solar System</h1>
    <%- include('partials/nav.ejs') %>

    <main>
        <div class="container">
            <div class="row content-row">
                <div class="col-md-6 mb-4">
                    <div class="content-card d-flex flex-column justify-content-center h-100">
                        <h2>Welcome to the Solar System</h2>
                        <p>
                            Explore the planets, learn about asteroids and comets, and view NASA's Astronomy Picture of the Day.
                        </p>
                    </div>
                </div>
                <div class="col-md-6 mb-4">
                    <div class="content-card">
                        <img class="hero-image" src="<%= randomImgURL %>" alt="Random solar system image">
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/footer.ejs') %>
</body>
</html>
