<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head.ejs') %>
</head>
<body>
    <h1 class="bg-info text-white p-3 m-0 page-title">The Solar System</h1>
    <%- include('partials/nav.ejs') %>

    <main>
        <div class="container">
            <div class="row content-row g-4">
                <div class="col-md-6">
                    <div class="content-card info-list">
                        <h2 class="text-center mb-4">NASA Picture of the Day</h2>
                        <p><strong>Title:</strong> <%= data.title %></p>
                        <p><strong>Date:</strong> <%= data.date %></p>
                        <p><strong>Explanation:</strong> <%= data.explanation %></p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="content-card">
                        <img class="pod-image" src="<%= data.url %>" alt="NASA Picture of the Day">
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/footer.ejs') %>
</body>
</html>
